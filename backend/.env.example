# ---- Process role: api | collector | worker (see docs/deployment/README.md §1) ----
APP_ROLE=api
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ---- Database (PostgreSQL + pgvector) — consumed by Prisma ----
DATABASE_URL=postgresql://sprintiq:sprintiq@localhost:5432/sprintiq?schema=public

# ---- Redis (queues, poll scheduling, rate-limit state, cache) ----
REDIS_URL=redis://localhost:6379

# ---- Auth (BC-2) ----
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=3600s

# ---- Collectors / integration (BC-0/BC-1) ----
# Base URL used when registering source webhooks (e.g. https://hooks.sprintiq.io)
PUBLIC_WEBHOOK_BASE_URL=http://localhost:3000
# Secret store provider for source credentials & webhook secrets: env | vault | aws-kms | gcp-sm
SECRETS_PROVIDER=env

# ---- AI (BC-11) ----
LLM_API_KEY=
LLM_DEFAULT_MODEL=claude-opus-4-8
