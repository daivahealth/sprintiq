# ---- Process role: api | collector | worker (see docs/deployment/README.md §1) ----
APP_ROLE=api
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ---- Database (PostgreSQL + pgvector) — consumed by Prisma ----
DATABASE_URL=postgresql://sprintiq:sprintiq@localhost:5432/sprintiq?schema=public

# ---- Redis (queues, poll scheduling, rate-limit state, cache) ----
REDIS_URL=redis://localhost:6379

# ---- Auth (BC-2) ----
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=3600s
# Platform bootstrap token to provision the first tenant + admin (POST /api/admin/tenants).
PROVISIONING_TOKEN=dev-provision-token

# ---- Collectors / integration (BC-0/BC-1) ----
# Base URL used when registering source webhooks (e.g. https://hooks.sprintiq.io)
PUBLIC_WEBHOOK_BASE_URL=http://localhost:3000
# Secret store provider for source credentials & webhook secrets: env | vault | aws-kms | gcp-sm
SECRETS_PROVIDER=env
# Webhook signing secret for the seeded GitHub connection (referenced by webhookSecretRef).
GITHUB_WEBHOOK_SECRET=dev-webhook-secret
# Master key for the DB-backed encrypted secret store (SecretsService) — lets an
# admin paste a real GitHub/Jira token into admin/configuration instead of
# setting a deploy-time env var. AES-256-GCM, so this must base64-decode to
# exactly 32 bytes. Generate with: openssl rand -base64 32
# Leave unset to disable pasting secrets in the UI (env-var refs still work).
SECRETS_ENCRYPTION_KEY=

# ---- AI (BC-11) ----
LLM_API_KEY=
LLM_DEFAULT_MODEL=claude-opus-4-8
